# 校园通知爬虫 环境变量配置
# 复制此文件为 .env 并填入你的真实信息
# .env 文件已被 .gitignore 忽略，不会提交到 GitHub

# 邮件通知（QQ 邮箱 SMTP）
EMAIL_SENDER=your_email@qq.com
EMAIL_PASSWORD=your_smtp_auth_code
EMAIL_RECIPIENTS=user1@qq.com,user2@gmail.com

# 钉钉机器人（可选，不需要就留空或删除）
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN
DINGTALK_SECRET=YOUR_SECRET

# 飞书机器人（可选）
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_HOOK
